const float FOG_ENTER = 65.0 / 128.0;

uint CeilDiv( uint numerator, uint denominator ) {
	return ( numerator + denominator - 1u ) / denominator;
}

const int SW_WRITE_RED = 1;
const int SW_WRITE_GREEN = 2;
const int SW_WRITE_BLUE = 4;
